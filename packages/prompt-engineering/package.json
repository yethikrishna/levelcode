```json
{
  "name": "@levelcode/prompt-engineering",
  "version": "1.0.0",
  "description": "Advanced prompt engineering library with template system and optimization tools",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun run build:cjs && bun run build:esm && bun run build-types",
    "build:cjs": "bun build ./src/index.ts --outdir ./dist --target node --format cjs --minify",
    "build:esm": "bun build ./src/index.ts --outfile ./dist/index.mjs --target node --format esm --minify",
    "build-types": "tsc --emitDeclarationOnly --outDir ./dist",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit -p ."
  },
  "sideEffects": false,
  "dependencies": {
    "@levelcode/common": "workspace:*",
    "@levelcode/internal": "workspace:*",
    "json-schema-to-ts": "^3.1.1",
    "nanoid": "^5.0.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "prompt",
    "prompt-engineering",
    "ai",
    "llm",
    "template",
    "optimization",
    "levelcode"
  ],
  "author": "Levelcode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/levelcode/prompt-engineering.git",
    "directory": "packages/prompt-engineering"
  }
}
