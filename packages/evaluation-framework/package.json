{"name": "@levelcode/evaluation-framework", "version": "1.0.0", "description": "Evaluation framework for LLM performance metrics", "main": "dist/index.js", "types": "dist/index.d.ts", "scripts": {"build": "bun build src/index.ts --outdir dist --target node && bun run build-types", "build-types": "tsc --emitDeclarationOnly", "dev": "bun --watch src/index.ts", "test": "bun test", "lint": "eslint src --ext .ts", "typecheck": "tsc --noEmit"}, "dependencies": {"@levelcode/common": "workspace:*", "@levelcode/internal": "workspace:*", "zod": "^3.22.4", "nanoid": "^5.0.4", "clsx": "^2.1.0", "chalk": "^5.3.0", "ora": "^8.0.1", "table": "^6.8.1"}, "devDependencies": {"@types/bun": "^1.1.0", "@types/node": "^20.11.0", "@typescript-eslint/eslint-plugin": "^7.0.0", "@typescript-eslint/parser": "^7.0.0", "eslint": "^8.56.0", "typescript": "^5.3.3"}, "peerDependencies": {"typescript": "^5.0.0"}}